# Ignore everything by default.
/*

# Keep the ignore policy itself versioned.
!/.gitignore

# Allow the only paths that should be pushed.
!/AGENTS.md
!/README.md
!/MILESTONE.md
!/agents/
!/agents/**
!/skills/
!/skills/**
/skills/**/__pycache__/
/skills/**/__pycache__/**

# Do not push bundled system skills.
/skills/.system/
/skills/.system/**
